<%- include('../partials/header', {title : 'Create User'}) %>

<div class="form-container">

    <h1>Create User</h1>

    <form action="/users/create" method="POST">

        <input
            type="text"
            name="name"
            placeholder="Enter Name"
            required
        >

        <input
            type="email"
            name="email"
            placeholder="Enter Email"
            required
        >

        <input
            type="number"
            name="age"
            placeholder="Enter Age"
            required
        >

        <button type="submit">
            Create User
        </button>

    </form>

</div>

<%- include('../partials/footer') %>